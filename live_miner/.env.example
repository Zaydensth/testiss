# Copy to repo root as .env and fill in. Loaded by run_miner.py.

# --- Wallet / chain (for the one-time `commit` and identity) ---
HOTKEY_SS58=                 # your registered SN123 hotkey ss58 (also the R2 object key)
BT_WALLET_NAME=default
BT_WALLET_HOTKEY=default
BT_CHAIN_ENDPOINT=finney     # mainnet SN123

# --- Cloudflare R2 (free tier) ---
# Create a bucket, an API token (Access Key), and enable a public r2.dev URL for the bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE=              # e.g. https://pub-xxxxxxxx.r2.dev  (commit URL = this + "/" + HOTKEY_SS58)

# --- Loop tuning ---
LOCK_SECONDS=30              # timelock maturation; guide suggests up to 3600 in prod
CYCLE_SECONDS=60             # resubmit cadence (~SAMPLE_EVERY=5 blocks)

# --- Data (VPS) ---
# If your VPS can reach api.binance.com directly, set this; otherwise leave default mirror.
# BINANCE_API_URL=https://api.binance.com
